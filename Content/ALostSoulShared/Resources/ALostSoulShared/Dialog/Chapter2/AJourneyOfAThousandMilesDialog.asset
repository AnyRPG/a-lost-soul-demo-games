  m_Name: AJourneyOfAThousandMilesDialog
  m_EditorClassIdentifier: 
  resourceName: A Journey Of A Thousand Miles
  displayName: 
  icon: {fileID: 0}
  iconBackgroundImage: {fileID: 0}
  description: 
  useRegionalDescription: 0

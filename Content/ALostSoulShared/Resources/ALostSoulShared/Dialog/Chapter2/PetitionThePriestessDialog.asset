  m_Name: PetitionThePriestessDialog
  m_EditorClassIdentifier: 
  resourceName: Petition The Priestess
  displayName: 
  icon: {fileID: 0}
  iconBackgroundImage: {fileID: 0}
  description: 
  useRegionalDescription: 0

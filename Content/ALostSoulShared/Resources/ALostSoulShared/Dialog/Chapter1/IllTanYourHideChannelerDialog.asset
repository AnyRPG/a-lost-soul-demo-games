  m_Script: {fileID: 11500000, guid: fd3ecde65e0933d4d8e78e24e9ae3820, type: 3}
  m_Name: IllTanYourHideChannelerDialog
  m_EditorClassIdentifier: 
  resourceName: I'll Tan Your Hide (Channeler)
  displayName: 
  icon: {fileID: 0}
  iconBackgroundImage: {fileID: 0}
  description: 
  useRegionalDescription: 0
  resourceDescriptionProfile: 
  automatic: 0
  repeatable: 0
  audioProfileName: 
  dialogNodes:
  - startTime: 0
    showTime: 10
    description: 'Now that you have a basic weapon to deal with the bunnies around
      the camp, you can begin collecting ingredients for more powerful weapons and
      armor.


      Master Impassive has asked you to craft a set of Initiates Robes
      and an Initiates Staff.'
    nextOption: How do I make those?
  - startTime: 0
    showTime: 10
    description: 'You will need 1 Birch Lumber and one Blue Gem for the staff.


      The
      shoes will require 1 Leather and one Flax.


      The robes will require 3
      additional Flax.'
    nextOption: Where do I get those?
  - startTime: 0
    showTime: 10
    description: 'Everything you need is here in the camp.


      Behind Master
      Impassive you will find a tree that is ready to cut down.


      There is
      Flax near the crafting table.


      Search the nearby rocks to find Blue
      Stones.'
    nextOption: What about the leather?
  - startTime: 0
    showTime: 10
    description: 'You can get that from the bunnies.


      Talk to me again and
      I''ll teach you how to turn their hides into Leather and find the Flax, Lumber,
      and Stones.'
    nextOption: I really have to wear dead bunny skins?
  - startTime: 0
    showTime: 10
    description: 'Yep.


      Then bring me the Rabbit Hides, the Flax, the Blue
      Stone, and the Lumber and I''ll teach you how to work that into weapons and
      armor.'
    nextOption: Are you sure about this?
  prerequisiteConditions: []

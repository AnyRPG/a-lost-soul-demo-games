  m_Name: AHardDaysWorkDialog
  m_EditorClassIdentifier: 
  resourceName: A Hard Days Work
  displayName: 
  icon: {fileID: 0}
  iconBackgroundImage: {fileID: 0}
  description: 
  useRegionalDescription: 0
  resourceDescriptionProfile: 
  automatic: 0

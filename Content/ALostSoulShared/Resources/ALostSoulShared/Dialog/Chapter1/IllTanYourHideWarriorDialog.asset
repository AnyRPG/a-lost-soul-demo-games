  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: fd3ecde65e0933d4d8e78e24e9ae3820, type: 3}
  m_Name: IllTanYourHideWarriorDialog
  m_EditorClassIdentifier: 
  resourceName: I'll Tan Your Hide (Warrior)
  icon: {fileID: 0}
  description: 
  resourceDescriptionProfile: 
  automatic: 0
  repeatable: 0
  audioProfileName: 
  dialogNodes:
  - startTime: 0
    showTime: 10
    description: 'Now that you have some basic weapons to deal with the bunnies around
      the camp, you can begin collecting ingredients for more powerful weapons and
      armor.


      Master Impassive has asked you to craft a suit of Initiates Plate Armor, a Copper
      Axe, a Copper Sword, and a Copper Shield.'
    nextOption: How do I make those?
  - startTime: 0
    showTime: 10
    description: 'You will need 1 Birch Lumber, 1 Leather, and 1 Copper Ore for the
      Copper Shield.


      Both the Copper Axe, and Copper Sword will require 1 Copper Ore each.


      The suit of Initiates Plate Armor will require 5 Leather and 5 Copper Ores.'
    nextOption: Where do I get those?
  - startTime: 0
    showTime: 10
    description: 'Everything you need is here in the camp.


      Behind Master Impassive you will find a tree that is ready to cut down.


      You can search the nearby rocks for Copper Ores.'
    nextOption: What about the Leather?
  - startTime: 0
    showTime: 10
    description: 'You can get that from the bunnies.


      Talk to me again and I''ll teach you how to turn their hides into Leather and
      find the Birch Lumber and Copper Ores.'
    nextOption: I really have to use dead bunny skins?
  - startTime: 0
    showTime: 10
    description: 'Yep.


      Then bring me the Hides, the Copper Ores, and the Birch Lumber and I''ll teach
      you how to work that into weapons and armor.'
    nextOption: Are you sure about this?
  prerequisiteConditions: []

  m_Name: ASecondChanceDialog
  m_EditorClassIdentifier: 
  resourceName: A Second Chance
  displayName: 
  icon: {fileID: 21300000, guid: 488535651c5862c418faf0f12ed3eff1, type: 3}
  iconBackgroundImage: {fileID: 0}
  description: 
  useRegionalDescription: 0

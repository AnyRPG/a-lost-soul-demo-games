  m_Name: ATearInRealityDialog
  m_EditorClassIdentifier: 
  resourceName: A Tear In Reality
  displayName: 
  icon: {fileID: 21300000, guid: 4401af1fc84ff934c96aac864510150c, type: 3}
  iconBackgroundImage: {fileID: 0}
  description: 
  useRegionalDescription: 0
  resourceDescriptionProfile: 
  optionalOverride: 0
